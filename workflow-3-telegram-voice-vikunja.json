            },
            {
              "name": "text",
              "value": "=Aufgabe erstellt: {{ $json.title }}{{ $json.description ? '\\nBeschreibung: ' + $json.description : '' }}\\nProjekt: {{ {6:'Inbox',7:'OeIF',8:'Home Lab',9:'IBM',10:'Cardomat'}[$json.project_id] || 'Inbox' }}{{ $json.due_date && !$json.due_date.startsWith('0001') ? '\\nFaellig: ' + $json.due_date.substring(0,10) : '' }}{{ $json.priority ? '\\nPrioritaet: ' + $json.priority + '/5' : '' }}"
            }
          ]
        },
        "options": {}
      },
