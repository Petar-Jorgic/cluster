    {
      "parameters": {
        "jsCode": "const body = $json.body;\nconst message = body.message;\nconst chat_id = message.chat.id;\n\nif (message.voice) {\n  return [{ json: { type: 'voice', file_id: message.voice.file_id, chat_id } }];\n} else if (message.text) {\n  return [{ json: { type: 'text', chatInput: message.text, chat_id } }];\n} else {\n  return [{ json: { type: 'unknown', chat_id } }];\n}"
      },
