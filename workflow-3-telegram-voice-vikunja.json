    {
      "parameters": {
        "method": "GET",
        "url": "http://vikunja.vikunja.svc.cluster.local:3456/api/v1/tasks",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer tk_ba2a509cbe18e5368df76e9de325f55e12506358"
            }
          ]
        },
        "options": {}
      },
      "id": "f1a2b3c4-1001-4a01-b001-000000000060",
      "name": "Search Tasks",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2500, 400]
    },
    {
      "parameters": {
        "jsCode": "const tasks = $input.all();\nconst extractData = $('Extract Task Data').item.json;\nconst action = extractData.action;\nconst searchTitle = extractData.task_title.toLowerCase();\nconst projectNames = {6:'Inbox', 7:'OeIF', 8:'Home Lab', 9:'IBM', 10:'Cardomat'};\nconst prioNames = {1:'Sehr niedrig', 2:'Niedrig', 3:'Mittel', 4:'Hoch', 5:'Dringend'};\n\nlet match = null;\nfor (const item of tasks) {\n  if (item.json.title && item.json.title.toLowerCase().includes(searchTitle)) {\n    match = item.json;\n    break;\n  }\n}\n\nif (!match) {\n  return [{ json: { confirmation_text: 'Task nicht gefunden: ' + extractData.task_title } }];\n}\n\nconst result = { task_id: match.id, title: match.title, action };\n\nif (action === 'done') {\n  result.update_body = JSON.stringify({ done: true });\n  result.confirmation_text = 'Aufgabe erledigt: ' + match.title + '\\nProjekt: ' + (projectNames[match.project_id] || 'Unbekannt');\n} else if (action === 'move') {\n  const targetId = extractData.target_project_id || 6;\n  result.update_body = JSON.stringify({ project_id: targetId });\n  result.confirmation_text = 'Aufgabe verschoben: ' + match.title + '\\nVon: ' + (projectNames[match.project_id] || 'Unbekannt') + '\\nNach: ' + (projectNames[targetId] || 'Unbekannt');\n} else if (action === 'edit') {\n  const fields = extractData.edit_fields || {};\n  result.update_body = JSON.stringify(fields);\n  let details = [];\n  if (fields.description) details.push('Beschreibung: ' + fields.description);\n  if (fields.due_date) details.push('Faellig: ' + fields.due_date.substring(0, 10));\n  if (fields.priority) details.push('Prioritaet: ' + (prioNames[fields.priority] || fields.priority));\n  result.confirmation_text = 'Aufgabe bearbeitet: ' + match.title + '\\n' + details.join('\\n');\n}\n\nreturn [{ json: result }];"
      },
