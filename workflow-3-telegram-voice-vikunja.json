      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/bot8518425010:AAEKw_yU8Y_LK9KzbUcfWkxGsZ4WiRxYN5Q/sendMessage",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "chat_id",
